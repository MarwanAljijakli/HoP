@model DeceptionGPTDashboard.Models.DashboardVm

@{
    var total = Model?.ActiveSessions?.Count ?? 0;
    var activeCount = Model?.ActiveSessions?.Count(s => (s.Status ?? "").ToUpper() == "ACTIVE") ?? 0;
    var closedCount = total - activeCount;
}

<!DOCTYPE html>
<html>
<head>
    <title>DeceptionGPT Dashboard</title>

    <style>
        body {
            background: #000;
            color: #00ff9a;
            font-family: monospace;
            padding: 30px;
        }

        h1 {
            font-size: 36px;
        }

        .stats {
            display: flex;
            gap: 20px;
            margin-bottom: 25px;
        }

        .card {
            border: 1px solid #00ff9a;
            padding: 15px 25px;
            width: 200px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid #00ff9a;
            padding: 10px;
        }

        th {
            background: #001a12;
        }

        .row-active {
            background: rgba(0,255,154,0.05);
        }
    </style>
</head>

<body>

<h1>DeceptionGPT Dashboard</h1>

<div class="stats">
    <div class="card">
        <div>Total Sessions</div>
        <div>@total</div>
    </div>

    <div class="card">
        <div>Active Sessions</div>
        <div>@activeCount</div>
    </div>

    <div class="card">
        <div>Closed Sessions</div>
        <div>@closedCount</div>
    </div>
</div>

<table>
    <tr>
        <th>Session</th>
        <th>IP</th>
        <th>Protocol</th>
        <th>Commands</th>
        <th>Status</th>
    </tr>
@foreach (var s in Model.ActiveSessions)
{
    var isActive = (s.Status ?? "").ToUpper() == "ACTIVE";
    <tr class="@(isActive ? "row-active" : "")">
        <td>@s.SessionId</td>
        <td>@s.AttackerIp</td>
        <td>@s.Protocol</td>
        <td>@s.CommandCount</td>
        <td>@s.Status</td>
    </tr>
}


</table>

</body>
</html>
