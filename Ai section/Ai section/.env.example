# Required: supply OPENAI_API_KEY via the shell environment, NOT this file.
#
# PowerShell:
#   $env:OPENAI_API_KEY = "sk-..."
# Bash:
#   export OPENAI_API_KEY=sk-...
#
# The cognitive engine reads OPENAI_API_KEY from os.environ only.

OPENAI_MODEL=gpt-4o-mini
TEMPERATURE=0.6

# Logstash forwarding is best-effort. The JSONL file on disk is the source of truth.
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5001
